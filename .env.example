# Slack bot token (xoxb-...)
SLACK_TOKEN=

# Slack app token (xapp-...)
SLACK_APP_TOKEN=

# Slack user token (xoxp-...)
SLACK_USER_TOKEN=

# Slack user ID of the selfbot account
USER_ID=

# Comma-separated list of Slack channel IDs of your personal channel(s).
# Example: C01234567,C08976543
PERSONAL_CHANNEL_IDS=

# Comma-separated list of user IDs allowed to use admin commands.
# Example: U01234567,U08976543
PERMITTED_USER_IDS=

# Slack user ID used for Hackatime stats.
# Leave empty to use USER_ID.
HACKATIME_USER_ID=

# Your LastFM username
LASTFM_USERNAME=

# Your LastFM API key (see README)
LASTFM_TOKEN=